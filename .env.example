# ═══════════════════════════════════════════════════════════════════════════════
# 🔧 SIGNAL ENGINE — ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in your values.
# All settings have sane defaults — only override what you need.

# ═══════════════════════════════════════════════════════════════════════════════
# 🌐 WEBSOCKET SERVER
# ═══════════════════════════════════════════════════════════════════════════════
# Network interface to bind to (0.0.0.0 = all interfaces)
WS_HOST=0.0.0.0
# Port for WebSocket connections
WS_PORT=8765
# Leave empty to disable auth (dev mode)
WS_SECRET=7a89Rkke0Vhc/glFj9+ofmRIh9XHLFclVNTLSqgUfxOMDu0Y1XtcTV837XfEC8QmSZAeIBpXHro5pyJdbnfAfTk+RtAVDOxw4/aS0ctQnxM4WTUkGV8V9Dm0NFCpjhz28AwY9V3UANsv3Sq8nkvNC9dcsRQQJ8iJfXd9xSCMwRLtK6BbfEnFwUkNOOyPO2Yj8tklggICFbkIPhv+Rx4T3A0ZjSUzSsr5Cr4vU3NXzWR8yVgEsG0fmttjBw8GfLWNWJPXgQ0Jsqw=
# Maximum concurrent WebSocket clients
MAX_WS_CLIENTS=10

# ═══════════════════════════════════════════════════════════════════════════════
# 🔌 LOCAL MT5 BRIDGE
# ═══════════════════════════════════════════════════════════════════════════════
# URL for MetaTrader 5 bridge API
LOCAL_BASE_URL=http://localhost:8000/api/v1/

# ═══════════════════════════════════════════════════════════════════════════════
# 🌍 TIMEZONE
# ═══════════════════════════════════════════════════════════════════════════════
# Trading session timezone (affects session filters)
SESSION_TIMEZONE=UTC

# ═══════════════════════════════════════════════════════════════════════════════
# ⏱️ TIMEFRAME PAIRS
# ═══════════════════════════════════════════════════════════════════════════════
# Format: htf:ltf (comma-separated for multiple pairs)
# HTF = Higher Timeframe (for trend/zones), LTF = Lower Timeframe (for entries)
TF_PAIRS=30min:5min,1h:5min,5min:1min

# ═══════════════════════════════════════════════════════════════════════════════
# 📊 HTF CANDLE HISTORY
# ═══════════════════════════════════════════════════════════════════════════════
# Number of HTF candles to analyze for zones
HTF_LOOKBACK=240
# Maximum number of historical signals to keep
HTF_OUTPUTSIZE=1000

# ═══════════════════════════════════════════════════════════════════════════════
# 🎯 SIGNAL QUALITY
# ═══════════════════════════════════════════════════════════════════════════════
# Minimum wick-to-body ratio for reversal patterns (0.5+ = long wick)
MIN_WICK_RATIO=0.51
# Maximum multiple of zone size for stop loss (safety cap)
MAX_SL_ZONE_MULT=2.0
# Minimum Risk/Reward ratio (1 = 1:1)
MIN_RR=1
# Maximum Risk/Reward ratio (global cap)
MAX_RR=5 

# ═══════════════════════════════════════════════════════════════════════════════
# 💰 PER-PAIR RR CAPS
# ═══════════════════════════════════════════════════════════════════════════════
# Format: HTF_min/LTF_min:cap (comma-separated for multiple pairs)
# Falls back to MAX_RR for any pair not listed here.
# Example: 5/1:2.5 → For 5min/1min pairs, cap RR at 2.5
TF_MAX_RR=60/5:5,30/5:5,5/1:3

# ═══════════════════════════════════════════════════════════════════════════════
# ⏳ SIGNAL LIFETIME
# ═══════════════════════════════════════════════════════════════════════════════
# How long a signal remains valid (in hours)
SIGNAL_EXPIRY_HOURS=120

# ═══════════════════════════════════════════════════════════════════════════════
# 🚧 ZONE LIMITS
# ═══════════════════════════════════════════════════════════════════════════════
# Maximum supply/demand zones per direction
MAX_HTF_ZONES_PER_DIR=1

# ═══════════════════════════════════════════════════════════════════════════════
# 🎮 FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════════════════
# Enable higher timeframe trend filtering
USE_TREND_FILTER=true
# Auto-move SL to breakeven after X pips
USE_BREAKEVEN=false
# Invalidate signals when zones break
USE_INVALIDATION=false
# Allow independent positions across timeframes
MULTI_TF_INDEPENDENT_POSITIONS=true
# Entry trigger model: candle_pattern | crt | all
ENTRY_MODEL=all

# ═══════════════════════════════════════════════════════════════════════════════
# ⚡ CIRCUIT BREAKER
# ═══════════════════════════════════════════════════════════════════════════════
# Stop trading after this many losses in a row
MAX_CONSECUTIVE_LOSSES=10
# How many hours to pause after hitting max losses
PAUSE_AFTER_STREAK_H=12

# ═══════════════════════════════════════════════════════════════════════════════
# 🌎 SESSION FILTER
# ═══════════════════════════════════════════════════════════════════════════════
# Enable trading session restrictions
USE_SESSION_FILTER=true
# Tokyo session (00:00-09:00 GMT+3)
SESSION_TOKYO_ENABLED=false
# London session (09:00-18:00 GMT+3)
SESSION_LONDON_ENABLED=true
# New York session (13:00-22:00 GMT+3)
SESSION_NY_ENABLED=true
# Comma-separated hours to block during London (e.g., "10,11")
BLOCKED_HOURS_LONDON=
# Comma-separated hours to block during NY session
BLOCKED_HOURS_NY=

# ═══════════════════════════════════════════════════════════════════════════════
# 📝 LOGGING
# ═══════════════════════════════════════════════════════════════════════════════
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=ERROR
# Directory where log files are stored
LOG_DIR=logs