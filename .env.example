# Copy this to .env and fill in your values.
# .env is git-ignored. Never commit real credentials.

MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=

# APEX_ENV: "paper" (default) or "live"
APEX_ENV=paper

# Required when APEX_ENV=live. Must be set explicitly to trade real money.
# APEX_LIVE_CONFIRM=YES_I_ACCEPT_RISK

# Emergency kill switch. Blocks new orders when order execution is enabled.
# APEX_DISABLE_TRADING=1

# YAML engine config. USE_CONFIG is also accepted.
APEX_CONFIG=config.yaml
