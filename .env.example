# ── Signal Engine — environment variables ─────────────────────────────────────
# Copy to .env and fill in your values.
# All settings have sane defaults — only override what you need.

# ── WebSocket server ───────────────────────────────────────────────────────────
WS_HOST=0.0.0.0
WS_PORT=8765
# leave empty to disable auth (dev mode)
WS_SECRET=
MAX_WS_CLIENTS=10

# ── Local MT5 bridge ───────────────────────────────────────────────────────────
LOCAL_BASE_URL=http://localhost:8000

# ── Timezone ───────────────────────────────────────────────────────────────────
SESSION_TIMEZONE=UTC

# ── Timeframe pairs ────────────────────────────────────────────────────────────
# Format: htf:ltf  (comma-separated for multiple pairs)
TF_PAIRS=5min:1min
# ,30min:5min,5min:1min

# ── HTF candle history ─────────────────────────────────────────────────────────
HTF_LOOKBACK=240
HTF_OUTPUTSIZE=1000

# ── Signal quality ─────────────────────────────────────────────────────────────
MIN_WICK_RATIO=0.51
MAX_SL_ZONE_MULT=2.0
MIN_RR=1.5
MAX_RR=2.5
# 0 = no ceiling

# ── Per-pair RR caps ───────────────────────────────────────────────────────────
# Format: HTF_min/LTF_min:cap  (comma-separated for multiple pairs)
# Falls back to MAX_RR for any pair not listed here.
# Example: TF_MAX_RR=5/1:2.5,60/5:8
TF_MAX_RR=5/1:2.5

# ── Signal lifetime ────────────────────────────────────────────────────────────
SIGNAL_EXPIRY_HOURS=120

# ── Zone limits ────────────────────────────────────────────────────────────────
MAX_HTF_ZONES_PER_DIR=1

# ── Feature flags ──────────────────────────────────────────────────────────────
USE_TREND_FILTER=true
USE_BREAKEVEN=true
USE_INVALIDATION=false
MULTI_TF_INDEPENDENT_POSITIONS=true
# Entry trigger model: candle_pattern | crt | all
ENTRY_MODEL=all

# ── Circuit breaker ────────────────────────────────────────────────────────────
MAX_CONSECUTIVE_LOSSES=10
PAUSE_AFTER_STREAK_H=12

# ── Session filter ─────────────────────────────────────────────────────────────
USE_SESSION_FILTER=true
SESSION_TOKYO_ENABLED=false
SESSION_LONDON_ENABLED=true
SESSION_NY_ENABLED=true
BLOCKED_HOURS_LONDON=9
BLOCKED_HOURS_NY=17,19

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=ERROR
LOG_DIR=logs