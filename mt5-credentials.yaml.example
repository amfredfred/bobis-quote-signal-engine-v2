# MT5 credential profiles — copy this to mt5-credentials.yaml and fill in your values.
# mt5-credentials.yaml is git-ignored. Never commit real credentials.
#
# In config.yaml, set:
#   mt5:
#     use: exness        ← picks the "exness" profile below
#
# All four fields are required for each profile.
# login must be a non-zero integer.

exness:
  login: 0
  password: ""
  server: "Exness-MT5Real5"
  terminal_path: "C:\\Program Files\\MetaTrader 5 EXNESS\\terminal64.exe"

